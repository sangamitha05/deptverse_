// ─────────────────────────────────────────────────────────────
// MODULAR COMPONENTS
// ─────────────────────────────────────────────────────────────

const Selector = ({ label, value, options, onChange, disabled = false }) => (
    <div className="flex-1 min-w-[200px]">
        <label className="block text-slate-400 text-xs font-semibold uppercase tracking-wider mb-2 ml-1">
            {label}
        </label>
        <div className="relative">
            <select
                value={value}
                onChange={(e) => onChange(e.target.value)}
                disabled={disabled}
                className={`w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-slate-200 outline-none appearance-none cursor-pointer transition-all hover:bg-white/10 focus:border-white/20 ${disabled ? 'opacity-50 cursor-not-allowed' : ''}`}
            >
                <option value="" className="bg-primary text-white">Select {label}</option>
                {options.map((opt) => (
                    <option key={opt.id || opt} value={opt.id || opt} className="bg-primary text-white">
                        {opt.name || opt}
                    </option>
                ))}
            </select>
            <ChevronDown size={16} className="absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none" />
        </div>
    </div>
)

const SectionHeader = ({ icon: Icon, title, color }) => (
    <div className="flex items-center gap-2 mb-4">
        <div className={`p-2 rounded-lg bg-${color}/10 border border-${color}/20`}>
            <Icon size={18} className={`text-${color}`} />
        </div>
        <h3 className="text-white font-semibold font-heading tracking-wide">{title}</h3>
    </div>
)

const ProgrammingContent = ({ content }) => (
    <div className="grid lg:grid-cols-2 gap-8">
        {/* Videos */}
        <div className="glass-card p-6">
            <SectionHeader icon={Video} title="Video Lectures" color="accent-blue" />
            <div className="space-y-3">
                {content.videos.map((video) => (
                    <div key={video.id} className="group flex items-center justify-between p-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5 transition-all cursor-pointer">
                        <div className="flex items-center gap-3">
                            <div className="w-10 h-10 rounded-full bg-accent-blue/20 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <Play size={16} className="text-accent-blue ml-1" />
                            </div>
                            <div>
                                <p className="text-white text-sm font-medium">{video.title}</p>
                                <p className="text-slate-500 text-xs">{video.duration}</p>
                            </div>
                        </div>
                        <div className="text-accent-blue p-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <Video size={16} />
                        </div>
                    </div>
                ))}
            </div>
        </div>

        {/* Practice & Notes */}
        <div className="space-y-6">
            <div className="glass-card p-6">
                <SectionHeader icon={Code2} title="Coding Practice" color="accent-teal" />
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {['Lab Exercises', 'Assignment Set', 'Quiz 1', 'Mock Test'].map((item) => (
                        <button key={item} className="flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/5 hover:border-accent-teal/30 transition-all text-left group">
                            <Terminal size={14} className="text-accent-teal" />
                            <span className="text-slate-300 text-sm group-hover:text-white">{item}</span>
                        </button>
                    ))}
                </div>
            </div>

            <div className="glass-card p-6">
                <SectionHeader icon={Terminal} title="Example Programs" color="accent-violet" />
                <div className="space-y-2">
                    {content.examplePrograms.map((prog, i) => (
                        <div key={i} className="flex items-center justify-between p-3 rounded-lg bg-black/20 text-xs">
                            <span className="text-slate-300">{prog.title}</span>
                            <span className="text-accent-violet-light font-mono px-2 py-0.5 rounded bg-accent-violet/10 border border-accent-violet/20">{prog.language}</span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
)

const TheoryContent = ({ content }) => (
    <div className="space-y-8">
        <div className="glass-card p-8">
            <SectionHeader icon={FileText} title="Auto Generated Short Summary" color="accent-blue" />
            <p className="text-slate-400 leading-relaxed text-sm italic">
                "{content.summary}"
            </p>
        </div>
        <div className="grid md:grid-cols-2 gap-6">
            <div className="glass-card p-6">
                <SectionHeader icon={Download} title="Important Exam Notes" color="accent-teal" />
                <div className="space-y-2">
                    {content.notes.map((note, i) => (
                        <div key={i} className="flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 cursor-pointer transition-all group">
                            <CheckCircle2 size={14} className="text-accent-teal" />
                            <span className="text-slate-300 text-sm group-hover:text-white">{note}</span>
                        </div>
                    ))}
                </div>
            </div>
            <div className="glass-card p-6">
                <SectionHeader icon={Lightbulb} title="Key Concepts" color="accent-violet" />
