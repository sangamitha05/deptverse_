)

const ContentRenderer = ({ subject }) => {
    if (!subject) {
        return (
            <div className="glass-card p-20 text-center">
                <div className="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
                    <BookOpen size={40} className="text-slate-600" />
                </div>
                <h2 className="text-2xl font-heading font-bold text-slate-500 mb-2">Subject Portal</h2>
                <p className="text-slate-600">Please select all parameters from the header to view specialized content</p>
            </div>
        )
    }

    return (
        <motion.div
            key={subject.id}
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5 }}
        >
            <div className="flex items-center gap-4 mb-10">
                <div className="w-16 h-16 rounded-2xl bg-gradient-to-br from-accent-blue to-accent-violet flex items-center justify-center shadow-lg">
                    <BookOpen size={30} className="text-white" />
                </div>
                <div>
                    <h1 className="text-4xl font-heading font-bold text-white mb-1">{subject.name}</h1>
                    <div className="flex gap-3">
                        <span className="text-accent-blue text-xs uppercase font-bold tracking-tighter bg-accent-blue/10 px-2 py-0.5 rounded border border-accent-blue/20">{subject.type.replace('_', ' ')}</span>
                        <span className="text-slate-500 text-xs">{subject.year} • {subject.semester}</span>
                    </div>
                </div>
            </div>

            {subject.type === 'programming' && <ProgrammingContent content={subject.content} />}
            {subject.type === 'theory' && <TheoryContent content={subject.content} />}
            {subject.type === 'theory_math' && <TheoryMathContent content={subject.content} />}
        </motion.div>
    )
}

export default function ELearning() {
    const [selectedYear, setSelectedYear] = useState('')
    const [selectedSemester, setSelectedSemester] = useState('')
    const [selectedSubjectId, setSelectedSubjectId] = useState('')
    const [selectedElectiveId, setSelectedElectiveId] = useState('')

    // Get categories for the current year/semester
    const availableCategories = useMemo(() => {
        if (!selectedYear || !selectedSemester) return []
        const relevant = subjectData.filter(sub => sub.year === selectedYear && sub.semester === selectedSemester)
        const cats = new Set(relevant.map(sub => sub.category).filter(Boolean))
        return Array.from(cats)
    }, [selectedYear, selectedSemester])

    // Filter subjects: hide electives, show common subjects + category placeholders
    const filteredSubjects = useMemo(() => {
        if (!selectedYear || !selectedSemester) return []
        const relevant = subjectData.filter(sub => sub.year === selectedYear && sub.semester === selectedSemester)

        // Commmon subjects (those without a category)
        const common = relevant.filter(sub => !sub.category)

        // Category placeholders
        const catOptions = availableCategories.map(cat => ({
            id: `cat:${cat}`,
            name: cat
        }))

        return [...common, ...catOptions]
    }, [selectedYear, selectedSemester, availableCategories])

    // Specific electives based on selected category placeholder
    const electiveOptions = useMemo(() => {
        if (!selectedSubjectId.startsWith('cat:')) return []
        const categoryName = selectedSubjectId.replace('cat:', '')
        return subjectData.filter(sub =>
            sub.year === selectedYear &&
            sub.semester === selectedSemester &&
            sub.category === categoryName
        )
    }, [selectedYear, selectedSemester, selectedSubjectId])

    const activeSubject = useMemo(() => {
        if (selectedSubjectId.startsWith('cat:')) {
            return subjectData.find(sub => sub.id === selectedElectiveId)
        }
        return subjectData.find(sub => sub.id === selectedSubjectId)
    }, [selectedSubjectId, selectedElectiveId])

    return (
        <div className="pt-20 min-h-screen">
            {/* Header Control Panel */}
            <section className="section-pad bg-primary-light/30 border-b border-white/5">
                <div className="max-w-7xl mx-auto px-6">
                    <div className="flex flex-wrap gap-6 items-end">
                        <Selector
                            label="Academic Year"
                            value={selectedYear}
                            options={years}
                            onChange={(val) => {
                                setSelectedYear(val)
                                setSelectedSubjectId('')
                                setSelectedElectiveId('')
                            }}
                        />
                        <Selector
                            label="Semester Type"
                            value={selectedSemester}
                            options={semesterTypes}
                            onChange={(val) => {
                                setSelectedSemester(val)
                                setSelectedSubjectId('')
                                setSelectedElectiveId('')
                            }}
                        />
                        <Selector
                            label="Subject"
                            value={selectedSubjectId}
                            options={filteredSubjects}
                            onChange={(val) => {
                                setSelectedSubjectId(val)
                                setSelectedElectiveId('')
                            }}
                            disabled={!selectedYear || !selectedSemester || filteredSubjects.length === 0}
                        />

                        {/* Professional Elective Sub-Selector */}
                        <AnimatePresence>
                            {selectedSubjectId.startsWith('cat:') && (
                                <motion.div
                                    initial={{ opacity: 0, x: -10 }}
                                    animate={{ opacity: 1, x: 0 }}
                                    exit={{ opacity: 0, x: -10 }}
                                    className="flex-1 min-w-[200px]"
                                >
                                    <Selector
                                        label="Select Elective"
                                        value={selectedElectiveId}
                                        options={electiveOptions}
                                        onChange={setSelectedElectiveId}
                                    />
                                </motion.div>
                            )}
                        </AnimatePresence>
                    </div>
                </div>
            </section>

            {/* Dynamic Content Section */}
            <section className="section-pad">
                <div className="max-w-7xl mx-auto px-6">
                    <ContentRenderer subject={activeSubject} />
                </div>
            </section>
        </div>
    )
}
