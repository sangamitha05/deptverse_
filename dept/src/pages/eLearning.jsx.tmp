                    {content.concepts.map((concept, i) => (
                        <div key={i} className="flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/5">
                            <div className="w-1.5 h-1.5 rounded-full bg-accent-violet shadow-[0_0_8px_rgba(124,58,237,0.5)]" />
                            <span className="text-slate-300 text-sm">{concept}</span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
)

const TheoryMathContent = ({ content }) => (
    <div className="space-y-8">
        <div className="glass-card p-8">
            <SectionHeader icon={FileText} title="Auto Generated Short Summary" color="accent-blue" />
            <p className="text-slate-400 leading-relaxed text-sm italic">
                "{content.summary}"
            </p>
        </div>
        <div className="grid md:grid-cols-2 gap-6">
            <div className="glass-card p-6">
                <SectionHeader icon={Variable} title="Key Formulas" color="accent-violet" />
                <div className="space-y-3">
                    {content.formulas.map((formula, i) => (
                        <div key={i} className="p-4 rounded-xl bg-white/5 border border-white/5 font-mono text-xs text-accent-violet-light">
                            {formula}
                        </div>
                    ))}
                </div>
            </div>
            <div className="glass-card p-6">
                <SectionHeader icon={HelpCircle} title="Important Problems" color="accent-teal" />
                <div className="space-y-2">
                    {content.problems.map((prob, i) => (
                        <div key={i} className="p-3 rounded-xl bg-white/5 border border-white/5 text-slate-300 text-sm">
                            <span className="text-accent-teal mr-2">#{i + 1}</span> {prob}
                        </div>
                    ))}
                </div>
            </div>
        </div>
